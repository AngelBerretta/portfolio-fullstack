generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  imageUrl    String
  codeUrl     String
  demoUrl     String
  category    String   // "fullstack" | "frontend" | "landing"
  featured    Boolean  @default(false)
  status      String?  // "live" | "coming-soon" | "in-progress"
  statusLabel String?
  order       Int      @default(0)
  tags        Tag[]    @relation("ProjectTags")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Tag {
  id       String    @id @default(cuid())
  name     String    @unique
  projects Project[] @relation("ProjectTags")
}

model Skill {
  id          String  @id @default(cuid())
  name        String
  description String?
  level       Int     @default(0)
  iconUrl     String?
  iconName    String?
  invertIcon  Boolean @default(false)
  category    String  // "frontend" | "backend" | "tools"
  order       Int     @default(0)
  createdAt   DateTime @default(now())
}

model Profile {
  id           String @id @default(cuid())
  bio          String
  avatarUrl    String
  location     String
  education    String
  experience   String
  currentFocus String
  cvUrl        String?
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

/// Registro de intentos de login fallidos, usado para rate limiting.
/// Las filas viejas se van borrando solas (ver lib/rate-limit.ts) — no
/// hace falta mantenimiento manual de esta tabla.
model LoginAttempt {
  id         String   @id @default(cuid())
  identifier String   // IP del request
  createdAt  DateTime @default(now())

  @@index([identifier, createdAt])
}
